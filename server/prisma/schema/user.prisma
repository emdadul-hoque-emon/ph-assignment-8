model User {
  id       String   @id @default(uuid())
  name     String
  email    String   @unique
  password String?
  role     UserRole @default(TRAVELER)

  avatar  String?
  bio     String?
  phone   String?
  city    String
  country String

  provider   AuthProvider? // e.g., "google", "facebook", "credentials"
  providerId String? // ID from the OAuth provider

  isEmailVerified Boolean @default(false)
  isDeleted       Boolean @default(false)

  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  trips             Trip[]
  tours             Tour[]
  reviews           Review[]           @relation("ReviewsByUser")
  guides            Review[]           @relation("Guide")
  emergencyContacts EmergencyContact[]
  loggedInDevices   LoggedInDevice[]
  twoFactorOTPs     OTP[]
  twoFactorAuth     TwoFactorAuth[]

  travelerProfile TravelerProfile?
  guideProfile    GuideProfile?
  adminProfile    AdminProfile?
}

enum AuthProvider {
  GOOGLE
  FACEBOOK
  CREDENTIALS
}

enum UserRole {
  TRAVELER
  GUIDE
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

model GuideProfile {
  id String @id @default(uuid())

  gender     Gender  @default(MALE)
  bloodGroup String?

  emergencyContactPhone    String?
  emergencyContactRelation String?

  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  experience  Int?
  languages   String[]
  specialties String[]
  aboutMe     String
  hourlyRate  Float?
  rating      Float?
  totalTours  Int       @default(0)
  bio         String?
  dateOfBirth DateTime?
  isVerified  Boolean   @default(false)
  isTopRated  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model TravelerProfile {
  id String @id @default(uuid())

  interests   String[]
  languages   String[]
  aboutMe     String
  gender      Gender    @default(MALE)
  bloodGroup  String?
  dateOfBirth DateTime?

  emergencyContactPhone    String?
  emergencyContactRelation String?

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminProfile {
  id           String            @id @default(uuid())
  permissions  AdminPermission[] // ✅ strongly typed
  isSuperAdmin Boolean           @default(false)

  gender     Gender  @default(MALE)
  bloodGroup String?

  emergencyContactPhone    String?
  emergencyContactRelation String?

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

enum AdminPermission {
  MANAGE_USERS
  MANAGE_TOURS
  MANAGE_BOOKINGS
  VIEW_ANALYTICS
  MANAGE_PAYMENTS
  SUPER_ADMIN_ACCESS
}
