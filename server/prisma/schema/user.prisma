model User {
  id       String   @id @default(uuid())
  name     String
  email    String   @unique
  password String
  role     UserRole @default(TRAVELER)

  avatar  String?
  bio     String?
  phone   String?
  city    String
  country String

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  guideProfile GuideProfile?
  trips        Trip[]
  tours        Tour[]
  reviews      Review[]      @relation("ReviewsByUser")
  guides       Review[]      @relation("Guide")
}

enum UserRole {
  TRAVELER
  GUIDE
  ADMIN
}

model GuideProfile {
  id String @id @default(uuid())

  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  experience  Int?
  languages   String[]
  specialties String[]
  aboutMe     String
  hourlyRate  Float?
  rating      Float?
  totalTours  Int      @default(0)
  bio         String?
  verified    Boolean  @default(false)
  isTopRated  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
